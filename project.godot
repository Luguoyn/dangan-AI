; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DR"
config/description="Danganronpa-style Class Trial Game"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"
run/main_scene="res://scenes/main.tscn"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
SaveLoadManager="*res://scripts/managers/save_load_manager.gd"
SceneManager="*res://scripts/managers/scene_manager.gd"
AudioManager="*res://scripts/managers/audio_manager.gd"
GameManager="*res://scripts/managers/game_manager.gd"
ScriptInterpreter="*res://scripts/managers/script_interpreter.gd"
EvidenceManager="*res://scripts/managers/evidence_manager.gd"
CharacterPortraitManager="*res://scripts/managers/character_portrait_manager.gd"
MainGame="*res://scripts/main_game.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

